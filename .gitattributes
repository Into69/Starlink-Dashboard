# Normalise line endings: store LF in git, checkout as-is on all platforms.
# This prevents Windows CRLF from breaking shell scripts on Linux/Pi.
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf

# Binary files — never touch
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
*.woff  binary
*.ttf   binary
*.eot   binary
